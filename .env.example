# ─── IISc RAG Platform — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values. NEVER commit .env to git.

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1500

# ── FastAPI ───────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_ENV=development
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Mock Mode (set true until n8n workflows are ready) ───────────────────────
MOCK_N8N=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragplatform
POSTGRES_USER=raguser
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://raguser:changeme_in_production@localhost:5432/ragplatform

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_INGEST_WEBHOOK_URL=http://localhost:5678/webhook/ingest
N8N_RETRIEVE_WEBHOOK_URL=http://localhost:5678/webhook/retrieve
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# ── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-...

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt

# ── Seed Admin (used by scripts/seed_admin.py) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
SEED_TENANT_NAME=IISc Demo
SEED_TENANT_SLUG=iisc-demo

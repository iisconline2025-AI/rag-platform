# ════════════════════════════════════════════════════════════════════════
# IISc Grounded Agentic RAG Platform — environment template
# ════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Locked model stack: Voyage embeddings + Voyage rerank + DeepSeek V4 Flash
# + Gemini 3.5 Flash (self-check) + DeepSeek V4 Pro (hard fallback) +
# OpenAI ($5 prepaid insurance / OCR vision).
# ════════════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-32-chars-or-more-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Mock toggle (flip to false once n8n workflows are live) ─────────────
MOCK_N8N=true

# ── Database (Neon Postgres + pgvector in prod; local docker for dev) ───
# Local docker default:
DATABASE_URL=postgresql+asyncpg://raguser:changeme@localhost:5432/ragplatform
# Neon prod example:
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxxx.aws.neon.tech/ragplatform?ssl=require
POSTGRES_PASSWORD=changeme

# ── n8n (RAG engine — all AI logic lives here) ─────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_INGEST_WEBHOOK_URL=http://localhost:5678/webhook/ingest
N8N_RETRIEVE_WEBHOOK_URL=http://localhost:5678/webhook/retrieve
N8N_EPHEMERAL_INGEST_WEBHOOK_URL=http://localhost:5678/webhook/ingest-ephemeral
N8N_BASIC_AUTH_PASSWORD=n8nadmin
N8N_WEBHOOK_URL=http://localhost:5678
N8N_CALLBACK_TOKEN=change-me-shared-secret-with-n8n

# ── Voyage AI (embeddings + reranker — FREE 200M tokens each) ──────────
# Sign up: https://www.voyageai.com/
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-4-large    # 1024 dims, multilingual + multimodal
VOYAGE_RERANK_MODEL=rerank-2.5

# ── DeepSeek (primary generation — V4 Flash; fallback V4 Pro) ──────────
# OpenAI-compatible API: https://platform.deepseek.com/
# BUY $5 PRO CREDIT BEFORE 31-MAY-2026 — 75% off promo expires.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro

# ── Google Gemini (self-check / faithfulness — free tier) ──────────────
# Sign up: https://aistudio.google.com/
GEMINI_API_KEY=
GEMINI_SELFCHECK_MODEL=gemini-3.5-flash

# ── OpenAI (insurance + multimodal OCR via gpt-4o vision) ──────────────
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini          # used by n8n OCR node for scanned PDFs
OPENAI_HARD_CAP_USD=10                   # safety cap, enforced in code

# ── WhatsApp / Twilio Sandbox ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Slack (stretch goal) ────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── File upload limits ─────────────────────────────────────────────────
UPLOAD_DIR=/uploads
MAX_UPLOAD_BYTES=26214400                # 25 MB — admin web upload
MAX_WHATSAPP_UPLOAD_BYTES=10485760       # 10 MB — WhatsApp ephemeral upload
MAX_PAGES_PER_DOC=500
MAX_BYTES_PER_TENANT=1073741824          # 1 GB total per tenant
MAX_UPLOADS_PER_HOUR=20                  # per tenant, slowapi-enforced
ALLOWED_MIME_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,image/png,image/jpeg

# ── Seed admin (run scripts/seed_admin.py once) ─────────────────────────
SEED_ADMIN_EMAIL=admin@iisc-demo.com
SEED_ADMIN_PASSWORD=changeme-strong-password
SEED_TENANT_NAME=IISc Demo Tenant
SEED_TENANT_SLUG=iisc-demo

# ── Frontend (Next.js) ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── MCP server (exposes /chat/query as MCP tools for Claude Desktop) ───
MCP_ENABLED=true
MCP_API_KEY=change-me-mcp-shared-secret
